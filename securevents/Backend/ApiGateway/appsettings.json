{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "users_route": {
        "ClusterId": "user_cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "X-Gateway-Key", "Set": "SecureEventsGatewayKey_ChangeThis" }
        ]
      },
      "events_route": {
        "ClusterId": "event_cluster",
        "Match": {
          "Path": "/api/events/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "X-Gateway-Key", "Set": "SecureEventsGatewayKey_ChangeThis" }
        ]
      },
      "bookings_route": {
        "ClusterId": "event_cluster",
        "Match": {
          "Path": "/api/bookings/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "X-Gateway-Key", "Set": "SecureEventsGatewayKey_ChangeThis" }
        ]
      },
      "payments_route": {
        "ClusterId": "event_cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "X-Gateway-Key", "Set": "SecureEventsGatewayKey_ChangeThis" }
        ]
      },
      "logs_route": {
        "ClusterId": "logging_cluster",
        "Match": {
          "Path": "/api/logs/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeader": "X-Gateway-Key", "Set": "SecureEventsGatewayKey_ChangeThis" }
        ]
      }
    },
    "Clusters": {
      "user_cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "event_cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "logging_cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://localhost:5003/"
          }
        }
      }
    }
  }
}
